{
    "name": "hamlive-oss",
    "imports": {
        "#@client/*": "./client/dist/public/js/*",
        "#@server/*": "./server/dist/*"
    },
    "version": "1.0.0",
    "main": "server/dist/server.js",
    "description": "Ham.Live — self-hostable web app for running amateur radio nets (open-source edition)",
    "scripts": {
        "start": "node server/dist/server.js",
        "setup": "node ./scripts/setup.js",
        "mongo:dev": "node ./scripts/devMongo.js",
        "gen-certs": "openssl req -x509 -newkey rsa:2048 -nodes -keyout server/dist/ssl/dev-server_key.pem -out server/dist/ssl/dev-server_cert.pem -days 3650 -subj \"/CN=localhost/O=hamlive-oss dev\" -addext \"subjectAltName=DNS:localhost,IP:127.0.0.1\"",
        "build": "tsc -p server/tsconfig.json && tsc -p client/tsconfig.json",
        "dev": "node ./scripts/dev.js",
        "test": "node --test \"test/**/*.test.mjs\"",
        "dev:watch": "cross-env NODE_ENV=development concurrently --kill-others \"tsc -p server/tsconfig.json -w\" \"tsc -p client/tsconfig.json -w\" \"nodemon --delay 2.5 server/dist/server.js\"",
        "sync:types": "node -e \"require('fs').copyFileSync('client/src/public/js/types/commonTypesupport.ts','server/src/types/commonTypesupport.ts')\""
    },
    "author": "Sean Lynch",
    "license": "MIT",
    "dependencies": {
        "@foundernest/namecase": "^1.0.5",
        "@sendgrid/mail": "^8.1.6",
        "@types/he": "^1.2.3",
        "ap-style-title-case": "^1.1.2",
        "axios": "^1.17.0",
        "bootstrap": "~5.1.3",
        "cookie-session": "^2.1.1",
        "dotenv": "^16.6.1",
        "ejs": "^3.1.10",
        "es6-dynamic-template": "^2.0.0",
        "express": "^4.22.2",
        "express-list-endpoints": "^6.0.0",
        "express-sse-ts": "^1.0.2",
        "fast-xml-parser": "^4.5.6",
        "gravatar": "^1.8.2",
        "he": "^1.2.0",
        "humanize-duration": "^3.33.2",
        "json-escaping": "^2.0.0",
        "lodash": "^4.17.21",
        "mongoose": "^6.13.9",
        "mongoose-type-email": "^1.1.2",
        "mongoose-unique-validator": "^3.1.0",
        "node-cache": "^5.1.2",
        "node-color-log": "^11.0.0",
        "node-emoji": "^2.2.0",
        "node-json-logger": "^0.0.17",
        "nodemailer": "^9.0.3",
        "object-hash": "^3.0.0",
        "passport": "^0.6.0",
        "passport-google-oauth20": "^2.0.0",
        "passport-magic-login": "^1.2.4",
        "response-time": "^2.3.4",
        "sanitize-html": "^2.17.4",
        "slugify": "^1.6.6",
        "stream-chat": "^9.45.1",
        "validator": "^13.15.15",
        "yaml": "^2.9.0"
    },
    "devDependencies": {
        "@types/bootstrap": "^5.2.10",
        "@types/express": "^4.17.21",
        "@types/lodash": "^4.14.202",
        "@types/object-hash": "^3.0.6",
        "@types/yargs": "^17.0.32",
        "concurrently": "^8.2.2",
        "cross-env": "^7.0.3",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.2",
        "eslint-config-standard-with-typescript": "^42.0.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-n": "^16.6.2",
        "eslint-plugin-prettier": "^5.2.3",
        "eslint-plugin-promise": "^6.6.0",
        "immer": "^10.1.1",
        "mongodb-memory-server": "^10.1.4",
        "nodemon": "^3.1.14",
        "prettier": "^3.4.2",
        "typescript": "^5.7.3",
        "yargs": "^17.7.2"
    }
}
