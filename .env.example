# hamlive-oss environment configuration
# Copy this file to .env (or run `npm run setup`) and adjust as needed.
#
# For a ZERO-ACCOUNT local test drive, the defaults below are enough:
# every external integration is optional and degrades gracefully when its
# variables are absent. See INSTALL.md for the full guide.

# ---- Core (required) ----
NODE_ENV=development
PORT=3000
# Display name shown in the UI (page titles, navbar, footer). Brand your instance
# for your club/group, e.g. APP_NAME="Springfield ARC Nets". Defaults to Ham.Live.
APP_NAME=Ham.Live
# Optional callsign rendered as a bordered block next to the app name in the
# navbar, e.g. APP_CALLSIGN=N1CCK. Unset = no callsign block (name only).
#APP_CALLSIGN=
# Public base URL of this instance (used for OAuth callbacks and email links).
# Local dev serves plain HTTP on localhost (no certificate warning). If you set
# HTTPS=true to serve dev over HTTPS, change this to https://localhost:3000.
BASE_URL=http://localhost:3000
# MongoDB connection string. Matches the bundled docker-compose.yml, which runs
# a single-node replica set (required for real-time/SSE change streams).
# directConnection=true is needed to talk to a single-node replica set locally.
MONGODB_URI=mongodb://localhost:27017/hamlive?directConnection=true
# Signing secrets. CHANGE THESE to long random values for any hosted instance.
COOKIE_SESSION_KEY=dev-cookie-key-change-me
MAGIC_LINK_SECRET=dev-magic-link-secret-change-me
LOG_LEVEL=debug

# ---- Deployment (optional) ----
# Serve local dev over HTTPS (self-signed cert) instead of plain HTTP. Off by
# default to avoid the browser's "not private" certificate warning on localhost.
# If you enable this, also set BASE_URL=https://localhost:3000 above.
# HTTPS=true
# Redirect HTTP->HTTPS in production when behind a TLS-terminating proxy/load
# balancer (Render, Fly, Railway, nginx, Caddy, a cloud LB, ...). Uses the
# standard x-forwarded-proto header, so it is platform-neutral. Leave unset for
# local dev or if TLS is handled in front of the app.
# FORCE_HTTPS=true
# If your proxy drops idle connections sooner/later than ~55s, tune the SSE
# keep-alive push interval ceiling (milliseconds).
# SSE_IDLE_TIMEOUT_MS=55000

# ---- Email / login delivery (optional) ----
# Two providers are supported: SendGrid (SENDGRID_API_KEY) or any SMTP relay
# (SMTP_HOST + friends). SendGrid wins when both are configured. With neither,
# magic sign-in links are printed to the SERVER CONSOLE so you can log in
# locally with no email provider. For hosted instances, set a sender your
# provider accepts in EMAIL_FROM.
# SENDGRID_API_KEY=
# EMAIL_FROM=Your Club Net <no-reply@yourclub.example>
#
# SMTP relay (any provider: Fastmail, Mailgun, your own postfix, ...).
# SMTP_SECURE=true means implicit TLS (usually port 465); on 587 the connection
# upgrades via STARTTLS automatically. Omit SMTP_USER/SMTP_PASS for an
# unauthenticated relay (e.g. a local test sink like Mailpit).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
#
# The "Net Close Report" — the post-net log emailed to the net owner when a net
# closes — uses a SendGrid dynamic template WHEN SENDING VIA SENDGRID. Create
# your own from the reference in docs/email-templates/net-close-report.html,
# then paste its template ID here. When unset, that one email is skipped;
# everything else still works. Over SMTP no template ID is needed: the report is
# rendered locally from server/dist/views/emails/netCloseReport.ejs.
# SENDGRID_NET_CLOSE_TEMPLATE_ID=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Google OAuth (optional) ----
# Without these, the login page shows email magic-link sign-in only.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <BASE_URL>/auth/google/redirect
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ---- GetStream chat (optional) ----
# Without these, real-time chat is disabled; the rest of the app works.
# Get keys at https://getstream.io/
# STREAM_API_KEY=
# STREAM_API_SECRET=

# ---- QRZ.com callsign lookup (optional) ----
# Without these, callsign profile enrichment is skipped.
# Requires a QRZ XML subscription: https://www.qrz.com/page/xml_data.html
# QRZ_USERNAME=
# QRZ_PASSWORD=

# ---- Reverse geocoding (optional, Azure Maps by default) ----
# Without GEO_KEY, member location resolution is skipped.
# GEO_KEY=

# ---- Ads & analytics (optional, OFF by default) ----
# The community edition ships with ads and analytics DISABLED. To turn either on,
# set its flag to true AND provide your OWN provider ID (never reuse someone
# else's account). Each one stays off unless both its flag and ID are present.
# Two analytics providers are supported; Plausible is preferred when both are
# configured (cookieless, self-hostable — https://plausible.io/docs).
# ADS_ENABLED=false
# ADPLUGG_ACCESS_CODE=          # your AdPlugg access code
# ANALYTICS_ENABLED=false
# GOOGLE_ANALYTICS_ID=          # your GA4 measurement id, e.g. G-XXXXXXXXXX
# PLAUSIBLE_DOMAIN=             # the data-domain of this instance, e.g. nets.example.org
# PLAUSIBLE_SRC=                # tracking script URL from your Plausible site settings, e.g.
#                               # https://analytics.example.org/js/pa-XXXXXXXX.js (v3) or .../js/script.js (legacy)

# ---- Support / donation link (optional) ----
# When SUPPORT_URL is set, a small "Support this site" link appears in the page
# footer (e.g. your Ko-fi, Liberapay, or club-dues page). SUPPORT_LABEL overrides
# the link text.
# SUPPORT_URL=
# SUPPORT_LABEL=Support this site

# ---- Misc (optional) ----
# Override the net-control command help link shown in the UI.
# CMD_HELP_URL=
