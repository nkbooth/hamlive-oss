<!DOCTYPE html>
<html lang="en">
<!-- hamlive-oss — MIT License. See LICENSE. -->

<head>
  <%- include('./partials/head') %>
  <%- include('./partials/pageTopFeatures') %>
  <title><%= server.appName %> <% if (server.logLevel !== "info") { %> (<%= server.logLevel %>) <% } %></title>
</head>

<body class="bg-dark hl-page">
  <%- include('./partials/adTopBar') %>
  <%- include('./partials/navbar', { user: user }) %>

  <main class="hl-dashboard">
    <section aria-labelledby="onair-heading">
      <div class="hl-sechead">
        <span class="hl-livedot" aria-hidden="true"></span>
        <h2 id="onair-heading">On the air</h2>
      </div>
      <hl-net-cards></hl-net-cards>
    </section>

    <section aria-labelledby="upnext-heading">
      <div class="hl-sechead">
        <h2 id="upnext-heading">Up next</h2>
      </div>
      <hl-net-upnext></hl-net-upnext>
    </section>

    <p class="hl-dash-hint">
      New here? <a href="/views/intro">Watch the how-to video</a> or read the <a href="/views/guide">guide</a>.
    </p>
  </main>

  <%- include('./partials/pageBottomFeatures') %>
  <script src="/js/byView/<%= VIEW %>/main.js" type="module"></script>
  <%- include('./partials/footer') %>
</body>

</html>
