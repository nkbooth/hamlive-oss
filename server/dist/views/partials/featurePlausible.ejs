<!--Begin: featurePlausible.ejs-->
<!-- Plausible Analytics (cookieless; plausible.io or self-hosted). This is the
     v3-style snippet: the init shim is required by the per-site pa-*.js
     scripts; with a legacy /js/script.js src it is a harmless no-op and the
     data-domain attribute identifies the site instead. -->
<script async data-domain="<%= server.plausibleDomain %>" src="<%= server.plausibleSrc %>"></script>
<script>
    window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
    plausible.init()
</script>
<!--End: featurePlausible.ejs-->
