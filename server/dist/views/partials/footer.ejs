<!--Begin: footer.ejs-->
<footer class="hl-footer">
  <div class="hl-footer-left">
    <span>&copy; <%= server.appName %> <%= (new Date( server.ts )).getFullYear() %></span>
    <a href="/views/privacypolicy">Privacy</a>
    <a href="/views/termsofuse">Terms</a>
    <a href="/views/cookiepolicy">Cookies</a>
    <% if (server.supportUrl) { %>
    <a href="<%= server.supportUrl %>" target="_blank" rel="noopener">
      <i class="bi bi-cup-hot"></i> <%= server.supportLabel || 'Support this site' %>
    </a>
    <% } %>
  </div>
  <div class="hl-footer-right">
    a self-hosted fork of
    <a href="https://www.ham.live" target="_blank" rel="noopener">Ham.Live</a>
    &middot; MIT License
  </div>
</footer>
<!--End: footer.ejs-->